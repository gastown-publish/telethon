# Copy to `.env` in this repo root (never commit `.env`).
# Get api_id / api_hash from https://my.telegram.org (user account, not BotFather).

TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+10000000000

# Forum / supergroup chat id (negative integer)
TELEGRAM_GROUP_ID=-1003810709807

# Telethon session file base path (no .session suffix; Telethon adds it)
TELETHON_SESSION_PATH=/home/you/gasclaw-workspace/telethon/data/tg_session

# First-time login: write OTP digits to this file (see README)
TELEGRAM_OTP_CODE_FILE=/tmp/tg_otp_code

# Integration test: which two bot usernames to exercise (no @)
TELEGRAM_TEST_GASCLAW_BOT=gasclaw_master_bot
TELEGRAM_TEST_MINIMAX_BOT=minimax_gastown_publish_bot

# Ping script: comma-separated usernames
TELEGRAM_TEST_PING_BOTS=gasclaw_master_bot,minimax_gastown_publish_bot,gasskill_agent_bot

# Optional: path to JSON (default: examples/bots.example.json in repo)
# TELETHON_BOTS_CONFIG=/path/to/bots.json
